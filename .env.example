# Copy this file to .env and fill in your values. .env is gitignored.

# Database connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fillmovie
DB_USER=root
DB_PASS=

# OMDb API key for the movie search (free key: https://www.omdbapi.com/apikey.aspx).
# Leave it blank to run without movie search — the rest of the app still works.
OMDB_API_KEY=
